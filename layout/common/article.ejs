<% if (!index && (post.toc || post.encrypt == true)) { %>
<!-- TOC 收起/展开功能 -->
<script data-pjax>
(function() {
    // 初始化 TOC 切换功能的函数
    function initTocToggle() {
        var tocWrapper = document.getElementById('toc-wrapper');
        var tocToggleBtn = document.getElementById('toc-toggle-btn');
        var tocTitle = document.getElementById('toc-title');
        var tocContent = document.getElementById('toc-content');
        var tocTitleIcon = document.getElementById('toc-title-icon');
        
        if (!tocWrapper || !tocToggleBtn) return;
        
        // 检查本地存储中的状态
        var isCollapsed = localStorage.getItem('toc-collapsed') === 'true';
        
        // 初始化状态 - 只操作 wrapper 的 class
        if (isCollapsed) {
            tocWrapper.classList.add('collapsed');
            tocWrapper.classList.remove('expanded');
        } else {
            tocWrapper.classList.add('expanded');
            tocWrapper.classList.remove('collapsed');
        }
        
        // 点击切换按钮
        tocToggleBtn.addEventListener('click', function() {
            var isNowCollapsed = tocWrapper.classList.contains('expanded');
            
            if (isNowCollapsed) {
                // 收起
                tocWrapper.classList.add('collapsed');
                tocWrapper.classList.remove('expanded');
                localStorage.setItem('toc-collapsed', 'true');
            } else {
                // 展开
                tocWrapper.classList.add('expanded');
                tocWrapper.classList.remove('collapsed');
                localStorage.setItem('toc-collapsed', 'false');
            }
        });
        
        // 点击 toc-title 收起/展开目录内容
        if (tocTitle && tocContent) {
            tocTitle.addEventListener('click', function() {
                var isContentCollapsed = tocContent.classList.contains('collapsed');
                
                if (isContentCollapsed) {
                    // 展开
                    tocContent.classList.remove('collapsed');
                    tocContent.classList.add('expanded');
                    if (tocTitleIcon) {
                        tocTitleIcon.classList.remove('fa-angle-up');
                        tocTitleIcon.classList.add('fa-angle-down');
                    }
                } else {
                    // 收起
                    tocContent.classList.add('collapsed');
                    tocContent.classList.remove('expanded');
                    if (tocTitleIcon) {
                        tocTitleIcon.classList.remove('fa-angle-down');
                        tocTitleIcon.classList.add('fa-angle-up');
                    }
                }
            });
            
            // 初始化状态
            tocContent.classList.add('expanded');
        }
    }
    
    // 立即执行初始化
    initTocToggle();
    
    // 同时提供一个全局函数，供整页模式手动调用
    window.initTocToggle = initTocToggle;
})();
</script>

<% if (post.encrypt == true) { %>
<!-- 加密文章 TOC 显示控制 -->
<script data-pjax>
(function() {
    var toc = document.getElementById('toc');
    if (!toc) return;
    
    // 检查文章是否已解密（文章内容是否可见且有实际内容）
    function checkDecrypted() {
        var articleEntry = document.querySelector('.article-entry');
        if (!articleEntry) return false;
        
        // 检查内容是否可见且有实际内容（超过100字符）
        var hasContent = articleEntry.innerHTML.length > 100;
        var isVisible = articleEntry.offsetParent !== null;
        
        return hasContent && isVisible;
    }
    
    // 根据解密状态显示/隐藏 TOC
    function updateTocVisibility() {
        if (checkDecrypted()) {
            toc.style.display = 'block';
        } else {
            toc.style.display = 'none';
        }
    }
    
    // 初始检查
    updateTocVisibility();
    
    // 监听点击事件（解密/加密按钮）
    document.addEventListener('click', function() {
        // 延迟检查，等待解密/加密操作完成
        setTimeout(updateTocVisibility, 100);
        setTimeout(updateTocVisibility, 500);
    });
    
    // 提供全局函数供外部调用
    window.showEncryptedToc = function() {
        toc.style.display = 'block';
    };
    window.hideEncryptedToc = function() {
        toc.style.display = 'none';
    };
})();
</script>
<% } %>
<% } %>