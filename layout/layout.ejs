<% if (['post', 'page', 'tags', 'categories'].includes(page.layout)) { %>
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title><%= page.title ? page.title + ' | ' + config.title : config.title %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <style>
    body { margin: 0; padding: 20px; }
    #post-main { max-width: 1000px; margin: 0 auto; }
    </style>
    <%- css('libs/font-awesome/css/font-awesome.min') %>
    <%- css('css/style') %>
    <%- js('libs/jquery/2.1.3/jquery.min') %>
    <%- js('libs/jquery/plugins/cookie/1.4.1/jquery.cookie') %>
    <% if (theme.plugins.lightgallery) { %>
        <%- css('libs/lightgallery/css/lightgallery.min') %>
        <%- js('libs/lightgallery/js/lightgallery.min') %>
        <%- js('libs/lightgallery/js/lg-thumbnail.min') %>
        <%- js('libs/lightgallery/js/lg-pager.min') %>
        <%- js('libs/lightgallery/js/lg-autoplay.min') %>
        <%- js('libs/lightgallery/js/lg-fullscreen.min') %>
        <%- js('libs/lightgallery/js/lg-zoom.min') %>
    <% } %>
    <% if (theme.plugins.busuanzi_count) { %>
        <script async src="<%- url_for('libs/busuanzi/2.3/busuanzi.pure.mini.js') %>"></script>
    <% } %>
</head>
<body>
    <section id="post-main"><%- body %></section>
    <%- js('js/main') %>
    <% if (theme.plugins.busuanzi_count) { %>
    <script>
    // 手动触发不蒜子统计
    document.addEventListener('DOMContentLoaded', function() {
        if (typeof bszCaller === 'object' && typeof bszTag === 'object') {
            bszCaller.fetch("//busuanzi.ibruce.info/busuanzi?jsonpCallback=BusuanziCallback", function(a) {
                bszTag.texts(a);
                bszTag.shows();
            });
        }
    });
    </script>
    <% } %>
    <script>
    function hexToRgb(hex) {
      if (!hex) return null;
      hex = hex.replace('#', '');
      let r = parseInt(hex.slice(0, 2), 16);
      let g = parseInt(hex.slice(2, 4), 16);
      let b = parseInt(hex.slice(4, 6), 16);
      return { r, g, b };
    }
    function adjustColor(color, adjustment) {
        if (!color) return null;
      let { r, g, b } = hexToRgb(color);
      r = Math.min(255, Math.max(0, r + adjustment));
      g = Math.min(255, Math.max(0, g + adjustment));
      b = Math.min(255, Math.max(0, b + adjustment));
      return `rgb(${r}, ${g}, ${b})`;
    }
    const BackColors = ['#FFFFFF', '#F0FFF0', '#FFFFF0'];
    let ColorIndex = 0;
    function changeBackgroundColor(newColor) {
        $('.outer, .widget-wrap h3, body, .article-inner, .article-inner .article-meta').css('background-color', newColor);
        $('.article-entry blockquote').css('background-color', adjustColor(newColor, -10)).css('border-left','4px solid #c8c8c8');
    }
    $(document).ready(function() {
        changeBackgroundColor(BackColors[ColorIndex]);
    });
    </script>
