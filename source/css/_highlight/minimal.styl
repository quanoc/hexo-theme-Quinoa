/*

Minimal style - 极简风格，适合树形结构和流程图展示
基于 ascetic 风格优化，添加圆角边框

*/

.highlight
    color: #24292e
    background: #fafbfc
    border: 1px solid #d0d7de
    border-radius: 6px
    padding: 8px 12px
    font-family: 'SFMono-Regular', 'Consolas', 'Liberation Mono', 'Menlo', monospace
    font-size: 14px
    line-height: 1.6
    box-shadow: none
    position: relative

    pre
        margin: 0
        padding: 0
        background: transparent

    .code
        .comment,
        .quote
            color: #6a737d
            font-style: italic

        .string,
        .variable,
        .template-variable,
        .symbol,
        .bullet,
        .section,
        .addition,
        .attribute,
        .link
            color: #032f62

        .keyword,
        .selector-tag,
        .name,
        .type,
        .strong
            color: #d73a49
            font-weight: 600

        .number,
        .literal
            color: #005cc5

        .title,
        .class .title
            color: #6f42c1
            font-weight: 600

        .tag,
        .attr
            color: #22863a

        .built_in,
        .builtin-name
            color: #005cc5

        .meta
            color: #6a737d

        .deletion
            color: #b31d28
            background: #ffeef0

        .emphasis
            font-style: italic

        .strong
            font-weight: 600
