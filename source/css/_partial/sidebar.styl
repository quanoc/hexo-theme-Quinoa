#sidebar
    @media mq-normal
        column(sidebar-column)
        margin-top: 48px
        max-height: 85%
        transition: transform 0.3s ease; /* 添加过渡动画-用于收起侧栏 */
    @media mq-tablet
        column(sidebar-column-tablet)
        transition: transform 0.3s ease;
    @media mq-mobile
        display: none;
    @media mq-mini
        position: fixed
        left: 0
        top: 0
        transform: translateX(-100%)
        transition: transform 0.3s ease
        z-index: 999
        width: 250px
        height: 100%
        background: #fff
        margin-top: 0
        max-height: 100%
        overflow-y: auto /* 内容过多时允许滚动 */
    @media mq-mini
        &.expanded
            transform: translateX(0)

/* 侧边栏向左移出可视区域 */
#sidebar.collapsed {
    position: absolute;
    transform: translateX(-100%);
}
/* 侧边栏隐藏时，调整按钮位置 */
#sidebar.collapsed + #toolbar-mid {
    left: 0;
}
/* 侧边栏收起时，main 区域左边距为 0 */
#sidebar.collapsed ~ #toolbar-mid + #main {
    margin-left: 0;
}

.widget
    @extend $base-style
    line-height: line-height
    word-wrap: break-word
    font-size: 0.9em
    ul, ol
        list-style: none
        margin: 0
        ul, ol
            margin: 0 20px
        ul
            list-style: disc
        ol
            list-style: decimal

.category-list-count
.tag-list-count
.archive-list-count
    padding-left: 5px
    color: color-grey
    font-size: 0.85em
    &:before
        content: "("
    &:after
        content: ")"

.tagcloud
    a
        display: inline-block
        margin-right: 10px
        &:before
            content: "#"

.widget-wrap
    // -1px to compensate for border-right
    margin: /* block-margin */ 0 -1px 0 0
    //background-color: color-background + 20%
    //border: 4px solid color-border-stretch
    //border-radius: 4px
    padding: 20px
    .widget-title
        height: 48px
    h3
        line-height: 37.3px
        background: color-meta-head
        margin: -20px -20px 0 -19px
        padding: 0 20px
        border: 1px solid #f7f7f7
        border-radius: 4px 4px 0 0
        a
            margin-top: 5px
            float: right
        a,
        span
            border-radius: 4px 4px 0 0
            //background: color-background + 20%
            font-size: 15px
            line-height: 18px
            padding: 5px 2px
            vertical-align:bottom
            i
                font-size: 18px
                vertical-align:bottom

.widget-title
    @extend $block-caption
    margin-bottom: 0

.widget
    padding: 15px 5px
    a
        color: color-sidebar-text
        text-decoration: none
        &:hover
            color: color-sidebar-text-dark
    ul, ol, dl
        ul, ol, dl
            margin-left: 15px
            list-style: disc
    ul, ol
        list-style: none
        li,
        .category-list-child
            padding: 10px 0
            font-size: font-size
            border-bottom: 1px solid border-color
            a
                color: color-sidebar-text
        ul, ol
            list-style: none
            li
                border: none
                &:last-child
                    padding-bottom: 0px
    ul:not(#recent-post), ol:not(#recent-post)
        li
            a
                &:before
                    color: #ccc
                    content: "\f0da"
                    font-size: 12px
                    margin-right: 6px
                    font-family: FontAwesome
                    transition: 0.2s ease
                &:hover:before
                    color: color-sidebar-text-dark

#toTop
    @extend $block
    display: none
    cursor: pointer
    text-align: center
    width: 35px
    height: 35px
    color: white
    font-size: 33px
    line-height: 30px
    background: color-default
    opacity: 0.8
    border-radius: 4px
    bottom: 32px
    margin: 8px
    position: fixed
    z-index: 2
    @media mq-mobile
        width: 48px
        height: 48px
        font-size: 32px
        line-height: 48px
    @media mq-mini
        width: 48px
        height: 48px
        font-size: 32px
        line-height: 48px
   

#recent-post
    li
        clearfix()
        padding: 10px 0 10px 94px
    &.no-thumbnail
        li
            padding: 8px 0
            border-bottom: 1px solid #f0f0f0
            &:last-child
                border-bottom: none
            &:hover
                background-color: #f9f9f9
                transition: background-color 0.2s ease
        li
            .item-inner
                padding-left: 5px
                .item-title
                    font-size: 14px
                    line-height: 1.4
                    margin-bottom: 4px
                    a
                        color: color-sidebar-text-dark
                        transition: all 0.2s ease
                        display: block
                        overflow: hidden
                        text-overflow: ellipsis
                        white-space: nowrap
                        &:hover
                            color: color-link
                            transform: translateX(3px)
                .item-meta
                    display: flex
                    justify-content: space-between
                    align-items: center
                    font-size: 12px
                    color: #999
                    .item-category
                        a
                            color: #999
                            &:hover
                                color: color-link
                            font-size: 11px
                            background-color: #f5f5f5
                            padding: 2px 6px
                            border-radius: 3px
                            transition: all 0.2s ease
                            &:hover
                                background-color: #e8f4ff
                    .item-date
                        color: #bbb
                        font-size: 11px
                        font-style: italic
                
#categories
    text-shadow: 0 1px 0 #FFFFFF
    font-size: 13px
    ul
        margin-top: -1px
        margin-bottom: 0
        //li:last-child
            //padding-bottom: 0
    li
        padding: 10px 0
        ul
            padding-left: 15px
            display: none
            margin-top: 5px
        &.directory.open > ul
            display: block
        &.directory
            font-weight: bold
            border-top: none;
            & > a
                color: #333
                &:hover
                    text-decoration: none
        &.directory:first-of-type
            border-top: 1px solid #f2f1f1;
        &.file
            font-weight: normal
            word-wrap: break-word
            &.active > a
                color: #fa8919
        li.file
            padding: 8px 0px 8px 1px
            word-wrap: break-word
        li.file:hover
            background-color: #fffaf4
        a,
        a:hover
            display: block
            text-decoration: none
        a:focus:before
            content: "↪"
            float: left
            margin-left: -13px
            font-weight: bold
            color: #333
        li.file >a
            color: #706b6b
        li.file >a:hover
            color: #fa8919
